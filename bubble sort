// USING VECTORS

#include <iostream> 
#include <vector>
using namespace std;

void bubbleSort(vector<int>& arr) 
{
    int n = arr.size();
    for (int i = 0; i<n-1; i++){
        for(int j =i+1; j<n; j++){
            if(arr[i]>arr[j]){
                swap(arr[i], arr[j]);
            }
        }
    }for(int i = 0; i<n; i++){
        cout<<arr[i]<<" ";
    }
}

int main() {
vector<int>arr= {3,4,12,2,55,100};
bubbleSort(arr);
}
