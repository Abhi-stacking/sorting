// USING VECTORS
#include <iostream>
#include <vector>
using namespace std;

void insertionSort(int n, vector<int> &arr){
    for(int i = 1; i<n; i++){
        int temp = arr[i];
        int j = i-1;
        for( ;j>=0;j--){
            if(arr[j]>temp){
                arr[j+1] = arr[j];
            }
            else{
                break;
            }
        }
        arr[j+1]=temp;
    }
    for(int i = 0; i<n; i++){
        cout<<arr[i]<<" ";
    }
}


int main() {
    vector <int> arr = {10,1,7,3,8,11};
    insertionSort(6,arr);
}
